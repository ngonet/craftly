# ═══════════════════════════════════════════════════════════════
# Craftly — Environment variables
#
# ⚠️  RENAME THIS FILE to `.env.example` after cloning:
#     mv env.example .env.example
#
# Copy to `.env` (git-ignored) and fill in real values.
# In Vercel, set these via `vercel env` or the dashboard.
# Locally, a root `.env` is loaded by tsx (API) and Vite (Web).
# Vite only exposes vars prefixed with `VITE_` to the browser.
# ═══════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────
# Supabase — Project
# Dashboard → Project Settings → API
# ───────────────────────────────────────────────────────────────
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key

# Server-side ONLY. Bypasses RLS. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ───────────────────────────────────────────────────────────────
# Supabase — JWT verification (consumed by the Fastify API)
#
# Two strategies, pick ONE:
#
#   (A) JWKS — asymmetric, rotating keys, RECOMMENDED.
#       Dashboard → Authentication → JWT Keys → enable asymmetric keys.
#       Set the JWKS URL below. Leave SUPABASE_JWT_SECRET empty.
#
#   (B) HS256 — legacy shared secret, fallback.
#       Dashboard → Project Settings → API → JWT Settings → JWT Secret.
#       Set SUPABASE_JWT_SECRET. Leave SUPABASE_JWKS_URL empty.
#
# The middleware auto-detects: JWKS takes precedence if both are set.
# ───────────────────────────────────────────────────────────────
SUPABASE_JWKS_URL=https://<your-project-ref>.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWT_SECRET=

# Token issuer — MUST match what Supabase signs into the `iss` claim.
SUPABASE_JWT_ISSUER=https://<your-project-ref>.supabase.co/auth/v1

# Token audience — Supabase uses "authenticated" for logged-in users.
SUPABASE_JWT_AUDIENCE=authenticated

# ───────────────────────────────────────────────────────────────
# Database — Prisma
#
# TWO connection strings are mandatory on Supabase + serverless:
#
#   DATABASE_URL → Transaction Pooler (port 6543) for RUNTIME queries.
#                  Serverless requires `pgbouncer=true&connection_limit=1`.
#
#   DIRECT_URL   → Direct connection (port 5432) for MIGRATIONS only.
#                  The pooler cannot run DDL; `prisma migrate` needs this.
#
# Get both from: Supabase Dashboard → Connect → (Transaction / Direct).
# ───────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres"

# Optional — Supabase CLI / CI
# `supabase link` / `supabase db pull` can read the DB password from env.
SUPABASE_DB_PASSWORD=your-database-password
# In CI or non-interactive shells, CLI commands can use an access token.
SUPABASE_ACCESS_TOKEN=sbp_your_personal_access_token
SUPABASE_PROJECT_ID=<your-project-ref>

# ───────────────────────────────────────────────────────────────
# API runtime (Fastify)
# ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:5173

# ───────────────────────────────────────────────────────────────
# Web runtime (Vite)
# `VITE_` prefix is REQUIRED for Vite to expose vars to the client.
# Never put secrets here — everything is bundled into the JS.
# ───────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://<your-project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
VITE_API_URL=http://localhost:3001
VITE_AUTH_REDIRECT_URL=http://localhost:5173
