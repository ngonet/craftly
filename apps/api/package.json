{
  "name": "@craftly/api",
  "version": "0.1.0",
  "private": true,
  "description": "Craftly API — Fastify + Prisma + Supabase, Hexagonal (simplified). Runs as a Vercel Function (Fluid Compute).",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=../../.env src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "db:generate": "node --env-file=../../.env ../../node_modules/prisma/build/index.js generate",
    "db:migrate": "node --env-file=../../.env ../../node_modules/prisma/build/index.js migrate dev",
    "db:deploy": "node --env-file=../../.env ../../node_modules/prisma/build/index.js migrate deploy",
    "db:seed": "node --env-file=../../.env ../../node_modules/prisma/build/index.js db seed --",
    "db:studio": "node --env-file=../../.env ../../node_modules/prisma/build/index.js studio",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "prisma": {
    "seed": "tsx --env-file-if-exists=../../.env prisma/seed.ts"
  },
  "dependencies": {
    "@craftly/shared": "*",
    "@fastify/cors": "^10.0.1",
    "@prisma/client": "^5.22.0",
    "fastify": "^5.1.0",
    "fastify-plugin": "^5.0.1",
    "jose": "^5.9.6",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@vercel/node": "^3.2.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
