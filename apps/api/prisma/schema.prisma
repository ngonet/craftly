// Craftly — Prisma schema
// Target: Supabase (Postgres) on Vercel (Fluid Compute).
// Runtime queries MUST use the Supabase Pooler (port 6543, transaction mode)
// via DATABASE_URL. Migrations use the direct connection (port 5432)
// via DIRECT_URL — transaction-pooled connections cannot run DDL.

generator client {
  provider      = "prisma-client-js"
  // rhel-openssl-3.0.x is the Vercel Node 20+ runtime target.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")  // Pooler: postgres://...@...pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
  directUrl = env("DIRECT_URL")    // Direct: postgres://...@db.<ref>.supabase.co:5432/postgres
}

// ─────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────

enum MetodoPago {
  EFECTIVO
  TRANSFERENCIA
}

// ─────────────────────────────────────────────────────────────
// User
// Mirrors Supabase `auth.users.id` (UUID). We keep a local row so
// we can FK everything by userId and enforce multi-tenant isolation
// at the DB level.
// ─────────────────────────────────────────────────────────────

model User {
  id        String   @id @db.Uuid
  email     String   @unique
  name      String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  products Product[]
  sales    Sale[]

  @@map("users")
}

// ─────────────────────────────────────────────────────────────
// Product
// Tenant-scoped by userId. `costoBase` is the artisan's cost
// (for margin calc). `priceSale` is the current list price.
// Stock is decremented atomically inside the Venta Rápida
// use case — never from the route handler.
// ─────────────────────────────────────────────────────────────

model Product {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  name      String
  costoBase Decimal  @map("costo_base") @db.Decimal(12, 2)
  priceSale Decimal  @map("price_sale") @db.Decimal(12, 2)
  stock     Int      @default(0)
  imageUrl  String?  @map("image_url")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  saleItems SaleItem[]

  // Hot paths: list-by-user, search-by-name within a user.
  @@index([userId])
  @@index([userId, name])
  @@map("products")
}

// ─────────────────────────────────────────────────────────────
// Sale
// Aggregate root for a ticket. Total is denormalized so feed
// queries (/ventas, /resumen-dia) don't have to re-aggregate
// SaleItems on every read.
// ─────────────────────────────────────────────────────────────

model Sale {
  id         String     @id @default(uuid()) @db.Uuid
  userId     String     @map("user_id") @db.Uuid
  metodoPago MetodoPago @map("metodo_pago")
  total      Decimal    @db.Decimal(12, 2)
  createdAt  DateTime   @default(now()) @map("created_at")

  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items SaleItem[]

  // Primary feed: "mis ventas de hoy", ordered desc by time.
  @@index([userId, createdAt(sort: Desc)])
  @@map("sales")
}

// ─────────────────────────────────────────────────────────────
// SaleItem
// unitPrice is a SNAPSHOT of Product.priceSale at sale time —
// price changes later must NOT rewrite history.
// ─────────────────────────────────────────────────────────────

model SaleItem {
  id        String  @id @default(uuid()) @db.Uuid
  saleId    String  @map("sale_id") @db.Uuid
  productId String  @map("product_id") @db.Uuid
  quantity  Int
  unitPrice Decimal @map("unit_price") @db.Decimal(12, 2)
  subtotal  Decimal @db.Decimal(12, 2)

  sale    Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([saleId])
  @@index([productId])
  @@map("sale_items")
}
